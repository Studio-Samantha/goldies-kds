<plist version="1.0">
  <dict>
    <key>Label</key>
    <string>com.goldieskds.backup</string>

    <key>ProgramArguments</key>
    <array>
      <string>/bin/zsh</string>
      <string>/Users/fullsailuniversity-samanthacarey/Desktop/goldies-kds-main/scripts/backup_to_desktop.sh</string>
    </array>

