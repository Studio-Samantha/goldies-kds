{
  "buildCommand": "rm -rf my-menu-app/public/assets/ragbrai my-menu-app/public/souvenirs.html my-menu-app/public/ragbrai.css my-menu-app/public/catalog.css && mkdir -p my-menu-app/public/assets && cp -R ragbrai-page/assets/ragbrai my-menu-app/public/assets/ && cp ragbrai-page/catalog.html my-menu-app/public/souvenirs.html && cp ragbrai-page/ragbrai.css my-menu-app/public/ragbrai.css && cp ragbrai-page/catalog.css my-menu-app/public/catalog.css && cd my-menu-app && npm install && npm run build",
  "outputDirectory": "my-menu-app/dist",
  "framework": "vite",
  "redirects": [
    {
      "source": "/drinkflow-kds",
      "destination": "https://drinkflowkds.com",
      "permanent": false
    },
    {
      "source": "/souvenirs",
      "destination": "/souvenirs.html",
      "permanent": false
    },
    {
      "source": "/souvenirs/",
      "destination": "/souvenirs.html",
      "permanent": false
    },
    {
      "source": "/drinkflow",
      "destination": "https://drinkflowkds.com",
      "permanent": false
    },
    {
      "source": "/drinkflow-survey",
      "destination": "https://drinkflowkds.com/#survey",
      "permanent": false
    },
    {
      "source": "/survey",
      "destination": "https://drinkflowkds.com/#survey",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/goldies-menu",
      "destination": "/index.html"
    },
    {
      "source": "/menu-board",
      "destination": "/index.html"
    },
    {
      "source": "/orders-up",
      "destination": "/index.html"
    },
    {
      "source": "/customer-orders",
      "destination": "/index.html"
    },
    {
      "source": "/drive-thru",
      "destination": "/index.html"
    },
    {
      "source": "/drive-thru-board",
      "destination": "/index.html"
    },
    {
      "source": "/volume-board",
      "destination": "/index.html"
    },
    {
      "source": "/drink-volume",
      "destination": "/index.html"
    },
    {
      "source": "/online-orders",
      "destination": "/index.html"
    },
    {
      "source": "/online-order-board",
      "destination": "/index.html"
    },
    {
      "source": "/online-ordering-beta",
      "destination": "/index.html"
    },
    {
      "source": "/order-beta",
      "destination": "/index.html"
    },
    {
      "source": "/self-order-kiosk",
      "destination": "/index.html"
    },
    {
      "source": "/kiosk",
      "destination": "/index.html"
    },
    {
      "source": "/developer",
      "destination": "/index.html"
    },
    {
      "source": "/dev",
      "destination": "/index.html"
    },
    {
      "source": "/studio-dashboard",
      "destination": "/index.html"
    },
    {
      "source": "/case-study/goldies",
      "destination": "/case-study-goldies.html"
    },
    {
      "source": "/api/:path*",
      "destination": "https://goldies-kds-backend.onrender.com/api/:path*"
    }
  ]
}
